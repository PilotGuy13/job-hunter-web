<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Forgot Password · AI Job Hunter</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      min-height: 100vh; background: #f8fafc;
      display: flex; align-items: center; justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    .card {
      width: 100%; max-width: 420px; background: #fff;
      border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      overflow: hidden;
    }
    .card-header-block {
      background: #1e3a5f; padding: 28px 32px; text-align: center; color: #fff;
    }
    .card-header-block h1 { font-size: 20px; font-weight: 800; margin: 8px 0 4px; }
    .card-header-block p  { font-size: 13px; opacity: 0.75; margin: 0; }
    .card-body { padding: 28px 32px; }
    .form-label  { font-size: 13px; font-weight: 600; color: #374151; }
    .form-control { border-radius: 8px; border: 1px solid #e2e8f0; font-size: 14px; }
    .form-control:focus { border-color: #1d4ed8; box-shadow: 0 0 0 3px rgba(29,78,216,0.1); }
    .btn-submit {
      background: #1d4ed8; color: #fff; border: none; border-radius: 8px;
      padding: 10px; font-size: 15px; font-weight: 600; width: 100%;
    }
    .btn-submit:hover { background: #1a44c7; }
    .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; border-radius: 8px; font-size: 13px; padding: 10px 14px; }
    .alert-error   { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; border-radius: 8px; font-size: 13px; padding: 10px 14px; }
  </style>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔒</text></svg>" type="image/svg+xml">
</head>
<body>
  <div class="card">
    <div class="card-header-block">
      <div style="font-size:28px;">🔑</div>
      <h1>Forgot Password</h1>
      <p>Enter your email and we'll send a reset link</p>
    </div>
    <div class="card-body">

      
        
      

      <form method="POST">
        <div class="mb-4">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control"
                 placeholder="your@email.com" autofocus required>
          <div class="form-text mt-1">Enter the email associated with your account.</div>
        </div>
        <button type="submit" class="btn-submit">Send Reset Link →</button>
      </form>

      <div class="text-center mt-4">
        <a href="/login" style="font-size:13px;color:#1d4ed8;text-decoration:none;">
          ← Back to Sign In
        </a>
      </div>
    </div>
  </div>
</body>
